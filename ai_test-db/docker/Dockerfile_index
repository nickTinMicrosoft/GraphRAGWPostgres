# Use official Postgres 15 image as base
FROM postgres:15

# Set environment variables (optional)
ENV POSTGRES_USER=postgres
ENV POSTGRES_PASSWORD=postgres
ENV POSTGRES_DB=mygraphdb

# Install build tools and dependencies for AGE + PGVector
RUN apt-get update && apt-get install -y \
    build-essential \
    git \
    postgresql-server-dev-15 \
    flex \
    bison \
    libxml2-dev \
    && rm -rf /var/lib/apt/lists/*

# Install PGVector extension
RUN git clone https://github.com/pgvector/pgvector.git /tmp/pgvector \
    && cd /tmp/pgvector \
    && make install \
    && rm -rf /tmp/pgvector

# Install Apache AGE (PG15 branch)
RUN git clone https://github.com/apache/age.git /tmp/age \
    && cd /tmp/age \
    && git checkout PG15 \
    && make PG_CONFIG=/usr/lib/postgresql/15/bin/pg_config install \
    && rm -rf /tmp/age

# Configure Postgres to load AGE at startup
RUN echo "shared_preload_libraries='age'" >> /usr/share/postgresql/postgresql.conf.sample

# Expose default Postgres port
EXPOSE 5432

